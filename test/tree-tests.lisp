    (cl-mock:dflet ((hrt:scene-create-fullscreen-node
                     (layer view output)
                     (declare (ignore layer view output))
                     (cffi:null-pointer)))
      (multiple-value-bind (frame output-node)
          (make-tree-for-tests)
        (declare (ignore frame))
        (let ((view (make-mock-view (cffi:null-pointer)))
              (visited nil))
