(defun %initialize-family (layer parent &rest children)
  (loop for c in children
        do (setf (tree:frame-parent c) parent))
  (setf (tree:frame-parent parent)
        layer))

(defmacro with-tree ((parent-spec &rest child-specs) &body body)
  (let ((container-name (gensym "layer-container"))
        (parent-var (car parent-spec))
        (child-vars (mapcar #'car child-specs)))
    (flet ((make-construction-call (spec)
             (destructuring-bind (&key x y width height view) (cdr spec)
               (list (car spec)
                     `(make-instance 'tree:view-frame :x ,x :y ,y
                                                      :view ,view
                                                      :width ,width
                                                      :height ,height
                                                      :parent ,container-name)))))
      (let* ((children (mapcar #'make-construction-call child-specs))
             (parent `(,parent-var
                       (make-tree-frame (list ,@child-vars) ,@(cdr parent-spec)))))
        `(let* ((,container-name (make-instance 'tree:layer-container
                                                :children nil
                                                :hrt-layer (cffi:null-pointer)))
                ,@children
                ,parent)
           (%initialize-family ,container-name ,parent-var ,@child-vars)
           ,@body)))))

